{
  "$schema": "https://docs.claude.com/schemas/settings.json",
  "_comment": "Committed so every contributor + Claude session inherits the destructive-command guardrail. Per-developer allow-lists live in settings.local.json (gitignored).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/check-destructive.sh",
            "statusMessage": "Scanning for destructive command patterns..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/post-compact-recall.sh",
            "statusMessage": "Re-grounding after compaction (R20)..."
          }
        ]
      }
    ]
  }
}
